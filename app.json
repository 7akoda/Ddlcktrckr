{
	"expo": {
		"name": "app1",
		"slug": "app1",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./images/Weapon/1600/Split_Shot.png",
		"scheme": "app1",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"ios": {
			"supportsTablet": true,
			"bundleIdentifier": "com.anonymous.app1"
		},
		"android": {
			"adaptiveIcon": {
				"backgroundColor": "#ffffff"
			},
			"edgeToEdgeEnabled": true,
			"package": "com.anonymous.app1"
		},
		"web": {
			"bundler": "metro",
			"output": "static"
		},
		"plugins": [
			[
				"expo-video",
				{
					"supportsBackgroundPlayback": true,
					"supportsPictureInPicture": true
				}
			],
			"expo-router",
			[
				"react-native-edge-to-edge",
				{
					"android": {
						"parentTheme": "Default",
						"enforceNavigationBarContrast": false
					}
				}
			],
			["expo-font", {}],
			"expo-web-browser",
			"expo-secure-store"
		],
		"experiments": {
			"typedRoutes": true
		},
		"extra": {
			"router": {},
			"eas": {
				"projectId": "3e2f7f75-ae60-4bad-b660-941c9539f8ec"
			}
		},
		"owner": "7akoda",
		"runtimeVersion": "1.0.0",
		"updates": {
			"url": "https://u.expo.dev/3e2f7f75-ae60-4bad-b660-941c9539f8ec"
		}
	}
}
